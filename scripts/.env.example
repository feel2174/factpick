# Supabase (필수)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsIn...

# PubMed (선택)
# NCBI API 키 받기: https://www.ncbi.nlm.nih.gov/account/settings/
# 있으면 10 req/s, 없으면 3 req/s
PUBMED_API_KEY=
PUBMED_EMAIL=youremail@example.com

# JCR Impact Factor 매핑 (선택)
# 와이프 ID로 Web of Science 접속 → JCR → Download CSV
# CSV 컬럼: "Journal name", "JIF" (또는 "Impact Factor")
JCR_CSV_PATH=/Users/yourname/factpick/data/jcr_2024.csv
